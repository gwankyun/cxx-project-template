            "configuration": "Debug"
        },
        {
            "name": "gcc-classic",
            "configurePreset": "gcc-classic",
            "configuration": "Debug"
        },
        {
            "name": "gcc",
            "configurePreset": "gcc",
            "configuration": "Debug"
        },
        {
            "name": "gcc-export",
            "configurePreset": "gcc-export",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "msvc-classic",
            "configurePreset": "msvc-classic",
