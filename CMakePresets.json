    "workflowPresets": [
        {
            "name": "msvc",
            "steps": [
                { "type": "configure", "name": "msvc" },
                { "type": "build", "name": "msvc" },
                { "type": "test", "name": "msvc" }
            ]
        },
        {
            "name": "clang",
            "steps": [
                { "type": "configure", "name": "clang" },
                { "type": "build", "name": "clang" },
                { "type": "test", "name": "clang" }
            ]
        },
        {
